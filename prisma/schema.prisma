// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "sqlite"
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Product {
  id       String   @id @default(cuid())
  slug     String   @unique
  code     String   @unique
  name     String
  category String
  image    String
  /// [StringList]
  tags     Json

  subType         String? // Engineering type (Standard, Valve Block, ...)
  operatingType   String? // Design Type (Direct acting, Pilot Operated, ...)
  actionType      String? // Functional Type (NC, NO, Universal, 5/2 way, ...)
  portConnections Int? // Port Connections (2, 3, 5)
  operatorSize    String? // unused by valve import; kept for future actuator/positioner products

  bodyMaterial String?
  sealMaterial String?
  description  String?
  remark       String?

  /// [ProductApprovals]
  approvals Json?

  /// [ProductSpecs]
  specs Json?

  variants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  size        String // SIZE (inch)
  type        String? // Type (thread/connection type)
  minPressure Float?
  maxPressure Float?
  orifice     String? // ORIFICE (mm) — raw string, handles composite values like "12/2.2"
  flowFactor  String? // FLOW FACTOR (LPM) — raw string, handles composite values
  optionCode  String? // suffix stripped from the original Model Number (e.g. "A", "EP", "V01")
  // distinguishing variants that share a base model code

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, size, type, minPressure, maxPressure, orifice, flowFactor, optionCode])
}

model Industry {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  bgKey         String?
  image         String?
  description   String
  sectionTitle  String
  overview      String
  /// [IndustryStats]
  stats         Json
  /// [IndustryWhyChoose]
  whyChoose     Json

  subIndustries SubIndustry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubIndustry {
  id                  String   @id @default(cuid())
  slug                String
  name                String
  description         String
  image               String?
  /// [StringList]
  partnerIds          Json     @default("[]")
  /// [StringList]
  storyIds            Json     @default("[]")
  challengesTitle     String
  solutionsTitle      String
  solutionsIntro      String
  /// [StringList]
  challenges          Json
  /// [StringList]
  solutions           Json
  /// [StringList]
  recommendedProducts Json

  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)
  industryId String

  createdAt DateTime @default(now())

  @@unique([industryId, slug])
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logo      String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalConfig {
  id        String   @id @default("global")
  /// [GlobalConfigData]
  data      Json
  updatedAt DateTime @updatedAt
}

model HomeSeo {
  id        String   @id @default("home")
  /// [HomeSeoData]
  data      Json
  updatedAt DateTime @updatedAt
}

model HomeSection {
  key       String   @id
  enabled   Boolean  @default(true)
  order     Int
  data      Json
  updatedAt DateTime @updatedAt
}

model CustomerStory {
  id        String   @id @default(cuid())
  quote     String
  author    String
  company   String
  image     String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enquiry {
  id           String   @id @default(cuid())
  industryName String
  fullName     String
  enquiryType  String
  product      String
  phone        String
  email        String
  country      String
  city         String
  company      String?
  designation  String?
  message      String
  fileUrl      String?
  createdAt    DateTime @default(now())
}
